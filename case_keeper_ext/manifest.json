{
  "manifest_version": 3,
  "name": "Case Keeper",
  "version": "1.0",
  "description": "Add quick case number search to Elastic Support portal",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://support.elastic.co/*",
    "https://elastic--c.vf.force.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://support.elastic.co/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://elastic--c.vf.force.com/apex/SupportConsoleSidebarButtons*"],
      "css": ["vf_subscribe.css"],
      "js": ["vf_subscribe.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
